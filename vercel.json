{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/(.*)",
      "missing": [
        {
          "type": "cookie",
          "key": "saromen_auth"
        }
      ],
      "dest": "/login"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "cookie",
          "key": "saromen_auth",
          "value": "saromen_private_access_v1"
        }
      ],
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/login"
    }
  ]
}
