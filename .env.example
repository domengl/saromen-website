# Runtime
NEXT_PUBLIC_SITE_URL=https://www.saromen.com
AUTH_SECRET=change-this-to-a-long-random-secret

# Basic auth for whole site
BASIC_AUTH_USERNAME=saradomen
BASIC_AUTH_PASSWORD=saradomen

# Prisma
DATABASE_URL=file:./prisma/dev.db

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional email
RESEND_API_KEY=
ORDER_FROM_EMAIL=orders@saromen.com

# Optional admin fallback
ADMIN_USERNAME=admin
ADMIN_PASSWORD=saromenadmin

# Google Sheets integration (service account)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Alternative single JSON credential (instead of EMAIL + PRIVATE_KEY)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional sheet tab names
GSHEET_TAB_ORDERS=Orders
GSHEET_TAB_INVENTORY=Inventory
GSHEET_TAB_CAPACITY=Capacity
GSHEET_TAB_PRODUCTS=Products
GSHEET_TAB_COUPONS=Coupons
GSHEET_TAB_SPECIAL_OFFERS=SpecialOffers
